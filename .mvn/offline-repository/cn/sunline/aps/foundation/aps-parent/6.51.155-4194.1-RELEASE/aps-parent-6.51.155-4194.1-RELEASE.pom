        <maven-dependency-plugin.version>3.3.0</maven-dependency-plugin.version>
        <git-commit-id-plugin.version>4.0.3</git-commit-id-plugin.version>
        <swagger.maven.plugin.version>3.1.8</swagger.maven.plugin.version>
        <swagger.codegen.maven.plugin.version>2.4.7</swagger.codegen.maven.plugin.version>
        <maven.assembly.plugin.version>3.6.0</maven.assembly.plugin.version>
        <aps.dist.maven.plugin.version>1.0.79-RELEASE</aps.dist.maven.plugin.version>
        <cyclonedx-maven-plugin.version>2.9.1</cyclonedx-maven-plugin.version>

        <!-- Codehaus Maven Plugin Version Management -->
        <buildnumber-maven-plugin.version>1.4</buildnumber-maven-plugin.version>
        <properties-maven-plugin.version>1.0.0</properties-maven-plugin.version>
        <versions-maven-plugin.version>2.3</versions-maven-plugin.version>

        <!-- Repository Management -->
        <yfb.dev.releases.url>http://proxy.yfb.sunline.cn/nexus-dev/content/repositories/releases/</yfb.dev.releases.url>
        <yfb.dev.snapshots.url>http://proxy.yfb.sunline.cn/nexus-dev/content/repositories/snapshots/</yfb.dev.snapshots.url>
        <yfb.prod.releases.url>http://proxy.yfb.sunline.cn/nexus-prod/content/repositories/releases/</yfb.prod.releases.url>
        <yfb.prod.snapshots.url>http://proxy.yfb.sunline.cn/nexus-prod/content/repositories/snapshots/</yfb.prod.snapshots.url>
        <aps.repos.releases.url>http://proxy.yfb.sunline.cn/nexus-prod/content/repositories/releases/</aps.repos.releases.url>
        <aps.repos.snapshots.url>http://proxy.yfb.sunline.cn/nexus-prod/content/repositories/snapshots/</aps.repos.snapshots.url>

        <!-- Dependency-Check, Disable Sonar Report -->
        <dependency.check.report.dir>${project.basedir}/dependency-check</dependency.check.report.dir>
        <nist.url>http://e-proxy.yfb.sunline.cn/repos/offline/nist</nist.url>
        <aps.sonar.host.url>http://10.22.1.102:9000</aps.sonar.host.url>
        <aps.sonar.token>sqa_bf249c8b9387f47f61f400f24d053f07e9976ad3</aps.sonar.token>

        <aps.foundation.parent.version>6.51.155-4194.1-RELEASE</aps.foundation.parent.version>
        <aps.dependencies.bom.version>${aps.foundation.parent.version}</aps.dependencies.bom.version>
        <aps.util.version>${aps.foundation.parent.version}</aps.util.version>
        <aps.spec.version>${aps.foundation.parent.version}</aps.spec.version>
        <aps.model.version>${aps.foundation.parent.version}</aps.model.version>
        <aps.apm.version>${aps.foundation.parent.version}</aps.apm.version>
        <aps.admin.version>${aps.foundation.parent.version}</aps.admin.version>
        <aps.boot.version>${aps.foundation.parent.version}</aps.boot.version>
        <aps.service.version>${aps.foundation.parent.version}</aps.service.version>
        <aps.config.version>${aps.foundation.parent.version}</aps.config.version>
        <aps.registry.discovery.version>${aps.foundation.parent.version}</aps.registry.discovery.version>
        <aps.sequence.version>${aps.foundation.parent.version}</aps.sequence.version>
        <aps.ops.api.version>${aps.foundation.parent.version}</aps.ops.api.version>
        <aps.cipher.version>${aps.foundation.parent.version}</aps.cipher.version>
        <aps.runtime.dist.enabled>false</aps.runtime.dist.enabled>
        <aps.runtime.dist.version>${aps.foundation.parent.version}</aps.runtime.dist.version>
    </properties>

    <dependencyManagement>
