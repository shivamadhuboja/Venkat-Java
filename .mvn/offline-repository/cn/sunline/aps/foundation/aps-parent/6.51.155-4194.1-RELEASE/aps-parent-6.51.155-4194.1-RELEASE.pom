            </dependency>

            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-service-api</artifactId>
                <version>${aps.service.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-service-engine</artifactId>
