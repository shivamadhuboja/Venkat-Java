            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-registry-discovery-core</artifactId>
                <version>${aps.registry.discovery.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-registry-discovery-starter-nacos</artifactId>
                <version>${aps.registry.discovery.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-registry-discovery-starter-k8s</artifactId>
                <version>${aps.registry.discovery.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-sequence-core</artifactId>
                <version>${aps.sequence.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-sequence-api</artifactId>
                <version>${aps.sequence.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-sequence-ops</artifactId>
                <version>${aps.sequence.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-sequence-starter</artifactId>
                <version>${aps.sequence.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-ops-api</artifactId>
                <version>${aps.ops.api.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-cipher</artifactId>
                <version>${aps.cipher.version}</version>
            </dependency>

            <!-- aps admin-->
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-admin-parent</artifactId>
                <version>${aps.admin.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-admin-starter</artifactId>
                <version>${aps.admin.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-admin-api</artifactId>
                <version>${aps.admin.version}</version>
            </dependency>

            <dependency>
