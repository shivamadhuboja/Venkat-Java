            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-service-rest</artifactId>
                <version>${aps.service.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-service-starter</artifactId>
                <version>${aps.service.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
