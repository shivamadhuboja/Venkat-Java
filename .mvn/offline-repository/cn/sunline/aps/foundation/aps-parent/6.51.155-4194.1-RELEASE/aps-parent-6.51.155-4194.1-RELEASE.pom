            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-config-starter-redis</artifactId>
                <version>${aps.config.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-config-starter-file</artifactId>
                <version>${aps.config.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-apm-api</artifactId>
                <version>${aps.apm.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-apm-core</artifactId>
                <version>${aps.apm.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
