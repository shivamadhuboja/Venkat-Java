            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-boot-starter</artifactId>
                <version>${aps.boot.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.sunline.aps.foundation</groupId>
                <artifactId>aps-config-api</artifactId>
